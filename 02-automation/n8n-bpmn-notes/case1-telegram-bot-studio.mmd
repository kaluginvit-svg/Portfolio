flowchart LR
    subgraph Онбординг
        A[/start] --> B[Сбор брифа]
        B --> C[AI уточнение]
        C --> D{Бриф полный?}
        D -->|Нет| E{Переспрос < 3?}
        E -->|Да| B
        E -->|Нет| F[Менеджер]
        D -->|Да| G[CRM черновик]
        F --> G
    end
    subgraph Оплата
        G --> H[Рассчитать]
        H --> I[ЮKassa ссылка]
        I --> J{Оплата?}
        J -->|Нет| I
        J -->|Да| K[CRM оплачено]
    end
    subgraph ИИ и деплой
        K --> L[GPT: контент]
        L --> M[Codex: код]
        M --> N[Деплой]
        N --> O{OK?}
        O -->|Да| P[Тест бот клиенту]
        O -->|Нет| Q[Алерт]
        P --> R[Принимаю]
        R --> S[Закрытие]
    end
    S --> T((Конец))
