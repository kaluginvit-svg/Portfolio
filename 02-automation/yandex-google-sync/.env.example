# Copy to .env and fill in.

YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
# Must match Redirect URL in the Yandex OAuth app (same string). Example:
# YANDEX_REDIRECT_URI=http://127.0.0.1:8899/
YANDEX_REDIRECT_URI=
# Where to save tokens after yandex-login (default: SYNC_STATE_DIR/yandex_token.json):
# YANDEX_TOKEN_PATH=
YANDEX_SYNC_PATH=/sync
# Права для REST API Диска (по умолчанию — два scope, как в консоли: чтение + запись):
# YANDEX_OAUTH_SCOPE=cloud_api:disk.read cloud_api:disk.write
# Если invalid_scope — попробуйте эндпоинты .ru: YANDEX_OAUTH_USE_RU=1

GOOGLE_SYNC_FOLDER_ID=
# Optional. If unset, a file named google_token.json in the project root is used when present.
# GOOGLE_OAUTH_TOKEN_JSON=
# Or service account JSON (share Drive folder with SA email):
GOOGLE_SERVICE_ACCOUNT_JSON=
# Or OAuth client secrets JSON (Desktop app); first sync opens browser; token in SYNC_STATE_DIR:
# GOOGLE_OAUTH_CLIENT_SECRETS=

GOOGLE_SHARED_DRIVE=0

SYNC_STATE_DIR=.sync_state
# Одновременная передача нескольких файлов (1 = как раньше; 4–8 часто быстрее при узком канале на один файл):
# SYNC_PARALLEL_WORKERS=4
SYNC_CONFLICT_POLICY=lww
# lww | branch | manual
SYNC_DELETIONS=0
GOOGLE_FULL_SCAN_EACH_RUN=0
