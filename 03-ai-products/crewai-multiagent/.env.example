# API через ProxyAPI (https://console.proxyapi.ru)
# Ключ из раздела «Ключи API» — подставьте свой
OPENAI_API_KEY=ваш_ключ_proxyapi

# По документации ProxyAPI: base_url с /v1, модель gpt-4o
OPENAI_API_BASE=https://api.proxyapi.ru/openai/v1
OPENAI_MODEL_NAME=gpt-4o

# Опционально: лимит токенов на ответ (снижает расход), например 1024 или 2048
# OPENAI_MAX_TOKENS=1024
