# Absolute path to the product-mcp Python project (folder containing registry.py)
PRODUCT_MCP_PATH=

# Optional: Python executable (default: python)
MCP_PYTHON=python

# Optional: if set, tool calls use HTTP POST {tool,payload} instead of spawning Python
# Example bridge must return JSON: { success, result } or { success: false, error }
MCP_BASE_URL=

# Directory for UI-uploaded temp files (absolute or relative to product-mcp-ui)
UPLOAD_DIR=./data/uploads

# Optional: public URL prefix for internal API (usually empty for same-origin)
INTERNAL_API_BASE_URL=

NEXT_PUBLIC_APP_NAME=product-mcp-ui
