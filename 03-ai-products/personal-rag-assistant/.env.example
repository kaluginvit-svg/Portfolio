PINECONE_API_KEY=
PINECONE_INDEX_NAME=
PROXYAPI_BASE_URL=https://openai.api.proxyapi.ru/v1
PROXYAPI_API_KEY=
# Эмбеддинги только через API (не sentence-transformers локально).
# Под индекс 3072: text-embedding-3-large. Под 1536: text-embedding-3-small.
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o-mini
OPENAI_VISION_DETAIL=low
SHORT_TERM_HISTORY_TURNS=6
PINECONE_USER_MEMORY_NAMESPACE=user-memory
PINECONE_KB_NAMESPACE=knowledge-base
KNOWLEDGE_BASE_DIR=knowledge_base
KNOWLEDGE_CHUNK_SIZE=1200
KNOWLEDGE_TOP_K=5
TELEGRAM_BOT_TOKEN=
