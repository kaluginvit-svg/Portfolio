# Copy to .env and adjust (do not commit .env)
DATABASE_URL=sqlite:///./data/crm.db
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
LOG_LEVEL=INFO
# Optional: OAuth token pickle (по умолчанию data/google_token.pickle в корне проекта)
# GOOGLE_TOKEN_PATH=data/google_token.pickle
# Optional: default path to OAuth client JSON (relative to project root)
# GOOGLE_CLIENT_SECRET_PATH=google_integration/client_secret.json
