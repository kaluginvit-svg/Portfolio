# Скопируйте в .env и заполните значения
BOT_TOKEN=

# Ключ ProxyAPI (личный кабинет https://proxyapi.ru) — можно задать так или как OPENAI_API_KEY
PROXYAPI_API_KEY=
# OPENAI_API_KEY=

# База API: по умолчанию ProxyAPI (нативный OpenAI-эндпоинт). Для прямого OpenAI:
# OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_BASE_URL=https://api.proxyapi.ru/openai/v1

# Имя модели в каталоге ProxyAPI (например gpt-4o, gpt-4o-mini, gpt-5-mini — что доступно у вас)
OPENAI_MODEL=gpt-4o-mini
# Необязательно: температура (многие новые модели допускают только default — тогда строку не задавайте)
# OPENAI_TEMPERATURE=0.3

# Сколько последних сообщений (user + assistant) хранить в памяти на чат
MEMORY_MAX_MESSAGES=5

# --- Видео Sora: только model (как openai.videos.create({ model, prompt })) ---
VIDEO_MODEL=sora-2

# --- Изображения: gpt-image-1.5 + quality low (см. OpenAI ImageModel / документацию GPT Image 1.5) ---
IMAGE_MODEL=gpt-image-1.5
IMAGE_QUALITY=low
IMAGE_SIZE=1024x1024
# Оценка $ за одну картинку (low 1024x1024; подстройте под ProxyAPI)
GPT_IMAGE_15_LOW_USD=0.009

# --- Оценка стоимости чата / отчёта (USD за 1M токенов; подстройте под ProxyAPI) ---
PRICE_INPUT_PER_1M_USD=0.15
PRICE_OUTPUT_PER_1M_USD=0.60
# Курс для вывода ₽ в main.py (если не задан — спросим в терминале). Для api.py: тело JSON usd_rub или эта строка
# USD_RUB_RATE=100
# Оценка Sora по секундам ролика (условно $/сек)
SORA2_USD_PER_SECOND=0.10

# Необязательно: путь к prompts.json относительно каталога проекта
# PROMPTS_PATH=prompts.json

# --- AI Client Report Generator (main.py, api.py): только ProxyAPI ---
# PROXYAPI_API_KEY, OPENAI_BASE_URL, OPENAI_MODEL; опционально OPENAI_TEMPERATURE.
# Оценка $: PRICE_INPUT_PER_1M_USD, PRICE_OUTPUT_PER_1M_USD; ₽: USD_RUB_RATE или ввод в main.py
