# Ключ API: OpenAI или ProxyAPI (обязательно)
OPENAI_API_KEY=sk-...

# URL прокси-API (если используете ProxyAPI вместо прямого OpenAI)
# ProxyAPI (proxyapi.ru): https://api.proxyapi.ru/openai/v1
OPENAI_BASE_URL=https://api.proxyapi.ru/openai/v1

# Проверять SSL при запросах к API (false — если у прокси самоподписанный сертификат)
OPENAI_SSL_VERIFY=true

# Модель (по умолчанию gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Передавать в промпты ссылку как есть (true) или подставлять HTML страницы (false)
USE_URL_DIRECTLY=false
