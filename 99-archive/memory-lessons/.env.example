# Telegram bot token from BotFather
BOT_TOKEN=

# Use one of keys below:
# 1) OpenAI key
OPENAI_API_KEY=
# 2) ProxyAPI key (OpenAI-compatible provider)
PROXYAPI_KEY=

# Optional for ProxyAPI or any OpenAI-compatible gateway.
# Example for ProxyAPI:
# OPENAI_BASE_URL=https://api.proxyapi.ru/openai/v1
OPENAI_BASE_URL=

# Optional: model name (default in code is gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Optional: embeddings model (default in long-memory bot is text-embedding-3-small)
OPENAI_EMBED_MODEL=text-embedding-3-small
