<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_Case1"
                  targetNamespace="http://bpmn.io/schema/bpmn">

  <bpmn:process id="Process_StudioBots" name="Студия Telegram-ботов: от заявки до продукта" isExecutable="false">
    <bpmn:documentation>Автоматизация студии по разработке Telegram-ботов: онбординг, оплата, ИИ-генерация кода и контента, деплой.</bpmn:documentation>

    <!-- Start -->
    <bpmn:startEvent id="StartEvent_1" name="Клиент нажимает /start">
      <bpmn:outgoing>Flow_Start_Onboard</bpmn:outgoing>
    </bpmn:startEvent>

    <!-- Онбординг и сбор требований -->
    <bpmn:userTask id="Task_Onboard" name="Сбор брифа (вопросы: тип бота, функции, дизайн)">
      <bpmn:incoming>Flow_Start_Onboard</bpmn:incoming>
      <bpmn:outgoing>Flow_Onboard_AI</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="Task_AI_Clarify" name="AI анализирует ответы и уточняет детали">
      <bpmn:incoming>Flow_Onboard_AI</bpmn:incoming>
      <bpmn:outgoing>Flow_AI_GateBrief</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_BriefComplete" name="Бриф полный?">
      <bpmn:incoming>Flow_AI_GateBrief</bpmn:incoming>
      <bpmn:outgoing>Flow_Gate_Reask</bpmn:outgoing>
      <bpmn:outgoing>Flow_Gate_CRM</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:exclusiveGateway id="Gateway_ReaskCount" name="Переспрос &lt; 3 раз?">
      <bpmn:incoming>Flow_Gate_Reask</bpmn:incoming>
      <bpmn:outgoing>Flow_Reask_Onboard</bpmn:outgoing>
      <bpmn:outgoing>Flow_Reask_Manager</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_Manager" name="Эскалация менеджеру">
      <bpmn:incoming>Flow_Reask_Manager</bpmn:incoming>
      <bpmn:outgoing>Flow_Manager_CRM</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="Task_SaveCRM_Draft" name="Запись в CRM (NocoDB), статус «черновик»">
      <bpmn:incoming>Flow_Gate_CRM</bpmn:incoming>
      <bpmn:incoming>Flow_Manager_CRM</bpmn:incoming>
      <bpmn:outgoing>Flow_CRM_Calc</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Расчёт стоимости и оплата -->
    <bpmn:userTask id="Task_Client_Calc" name="Клиент нажимает «Рассчитать»">
      <bpmn:incoming>Flow_CRM_Calc</bpmn:incoming>
      <bpmn:outgoing>Flow_Calc_Price</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="Task_CalcPrice" name="Расчёт по прайс-шаблону (база + опции)">
      <bpmn:incoming>Flow_Calc_Price</bpmn:incoming>
      <bpmn:outgoing>Flow_Price_Link</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_GenPaymentLink" name="Генерация ссылки ЮKassa, отправка клиенту">
      <bpmn:incoming>Flow_Price_Link</bpmn:incoming>
      <bpmn:outgoing>Flow_Link_Pay</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:receiveTask id="Task_Payment" name="Ожидание оплаты (вебхук ЮKassa)">
      <bpmn:incoming>Flow_Link_Pay</bpmn:incoming>
      <bpmn:outgoing>Flow_Pay_Gate</bpmn:outgoing>
    </bpmn:receiveTask>
    <bpmn:exclusiveGateway id="Gateway_Payment" name="Оплата успешна?">
      <bpmn:incoming>Flow_Pay_Gate</bpmn:incoming>
      <bpmn:outgoing>Flow_Pay_Retry</bpmn:outgoing>
      <bpmn:outgoing>Flow_Pay_UpdateCRM</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_RetryLink" name="Отправка ссылки для повторной оплаты">
      <bpmn:incoming>Flow_Pay_Retry</bpmn:incoming>
      <bpmn:outgoing>Flow_Retry_Pay</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_CRM_Paid" name="Статус в CRM → «оплачено», чек клиенту">
      <bpmn:incoming>Flow_Pay_UpdateCRM</bpmn:incoming>
      <bpmn:outgoing>Flow_Paid_AI</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- ИИ-генерация кода и контента -->
    <bpmn:serviceTask id="Task_AI_Content" name="GPT-4: приветствия, меню, тексты рассылок">
      <bpmn:incoming>Flow_Paid_AI</bpmn:incoming>
      <bpmn:outgoing>Flow_Content_Code</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_AI_Code" name="Codex/Completion: генерация Python-кода бота (шаблон aiogram)">
      <bpmn:incoming>Flow_Content_Code</bpmn:incoming>
      <bpmn:outgoing>Flow_Code_Image</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_AI_Image" name="DALL·E: аватарка бота">
      <bpmn:incoming>Flow_Code_Image</bpmn:incoming>
      <bpmn:outgoing>Flow_Image_Gate</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_AIFail" name="Генерация успешна?">
      <bpmn:incoming>Flow_Image_Gate</bpmn:incoming>
      <bpmn:outgoing>Flow_AIFail_Retry</bpmn:outgoing>
      <bpmn:outgoing>Flow_AI_GitLab</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_AIRetry" name="Повтор до 3 раз, затем уведомление в Telegram команде">
      <bpmn:incoming>Flow_AIFail_Retry</bpmn:incoming>
      <bpmn:outgoing>Flow_Retry_AI</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_SaveGitLab" name="Код в GitLab, контент в БД">
      <bpmn:incoming>Flow_AI_GitLab</bpmn:incoming>
      <bpmn:outgoing>Flow_GitLab_Deploy</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Деплой тестового бота -->
    <bpmn:serviceTask id="Task_Deploy" name="CI/CD: Docker-образ, деплой на сервер, временный токен">
      <bpmn:incoming>Flow_GitLab_Deploy</bpmn:incoming>
      <bpmn:outgoing>Flow_Deploy_Gate</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_Deploy" name="Деплой успешен?">
      <bpmn:incoming>Flow_Deploy_Gate</bpmn:incoming>
      <bpmn:outgoing>Flow_Deploy_Alert</bpmn:outgoing>
      <bpmn:outgoing>Flow_Deploy_Notify</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_DeployAlert" name="Алерт в Telegram техподдержки">
      <bpmn:incoming>Flow_Deploy_Alert</bpmn:incoming>
      <bpmn:outgoing>Flow_Alert_End</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_SendTestBot" name="Отправка клиенту ссылки на тестового бота">
      <bpmn:incoming>Flow_Deploy_Notify</bpmn:incoming>
      <bpmn:outgoing>Flow_Notify_Accept</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="Task_Client_Accept" name="Клиент: «Принимаю работу»">
      <bpmn:incoming>Flow_Notify_Accept</bpmn:incoming>
      <bpmn:outgoing>Flow_Accept_Close</bpmn:outgoing>
    </bpmn:userTask>

    <!-- Передача и закрытие -->
    <bpmn:serviceTask id="Task_Close" name="Акт, инструкция на email, статус «завершён», follow-up в CRM">
      <bpmn:incoming>Flow_Accept_Close</bpmn:incoming>
      <bpmn:outgoing>Flow_Close_End</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="EndEvent_1" name="Проект закрыт">
      <bpmn:incoming>Flow_Close_End</bpmn:incoming>
      <bpmn:incoming>Flow_Alert_End</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Reask loop back -->
    <bpmn:sequenceFlow id="Flow_Reask_Onboard" sourceRef="Gateway_ReaskCount" targetRef="Task_Onboard" name="Да" />
    <bpmn:sequenceFlow id="Flow_Retry_Pay" sourceRef="Task_RetryLink" targetRef="Task_Payment" name="Повтор оплаты" />
    <bpmn:sequenceFlow id="Flow_Retry_AI" sourceRef="Task_AIRetry" targetRef="Task_AI_Content" name="Повтор ИИ" />

    <!-- Main flows -->
    <bpmn:sequenceFlow id="Flow_Start_Onboard" sourceRef="StartEvent_1" targetRef="Task_Onboard" />
    <bpmn:sequenceFlow id="Flow_Onboard_AI" sourceRef="Task_Onboard" targetRef="Task_AI_Clarify" />
    <bpmn:sequenceFlow id="Flow_AI_GateBrief" sourceRef="Task_AI_Clarify" targetRef="Gateway_BriefComplete" />
    <bpmn:sequenceFlow id="Flow_Gate_Reask" sourceRef="Gateway_BriefComplete" targetRef="Gateway_ReaskCount" name="Нет" />
    <bpmn:sequenceFlow id="Flow_Gate_CRM" sourceRef="Gateway_BriefComplete" targetRef="Task_SaveCRM_Draft" name="Да" />
    <bpmn:sequenceFlow id="Flow_Reask_Manager" sourceRef="Gateway_ReaskCount" targetRef="Task_Manager" name="Нет" />
    <bpmn:sequenceFlow id="Flow_Manager_CRM" sourceRef="Task_Manager" targetRef="Task_SaveCRM_Draft" />
    <bpmn:sequenceFlow id="Flow_CRM_Calc" sourceRef="Task_SaveCRM_Draft" targetRef="Task_Client_Calc" />
    <bpmn:sequenceFlow id="Flow_Calc_Price" sourceRef="Task_Client_Calc" targetRef="Task_CalcPrice" />
    <bpmn:sequenceFlow id="Flow_Price_Link" sourceRef="Task_CalcPrice" targetRef="Task_GenPaymentLink" />
    <bpmn:sequenceFlow id="Flow_Link_Pay" sourceRef="Task_GenPaymentLink" targetRef="Task_Payment" />
    <bpmn:sequenceFlow id="Flow_Pay_Gate" sourceRef="Task_Payment" targetRef="Gateway_Payment" />
    <bpmn:sequenceFlow id="Flow_Pay_Retry" sourceRef="Gateway_Payment" targetRef="Task_RetryLink" name="Нет" />
    <bpmn:sequenceFlow id="Flow_Pay_UpdateCRM" sourceRef="Gateway_Payment" targetRef="Task_CRM_Paid" name="Да" />
    <bpmn:sequenceFlow id="Flow_Paid_AI" sourceRef="Task_CRM_Paid" targetRef="Task_AI_Content" />
    <bpmn:sequenceFlow id="Flow_Content_Code" sourceRef="Task_AI_Content" targetRef="Task_AI_Code" />
    <bpmn:sequenceFlow id="Flow_Code_Image" sourceRef="Task_AI_Code" targetRef="Task_AI_Image" />
    <bpmn:sequenceFlow id="Flow_Image_Gate" sourceRef="Task_AI_Image" targetRef="Gateway_AIFail" />
    <bpmn:sequenceFlow id="Flow_AIFail_Retry" sourceRef="Gateway_AIFail" targetRef="Task_AIRetry" name="Ошибка" />
    <bpmn:sequenceFlow id="Flow_AI_GitLab" sourceRef="Gateway_AIFail" targetRef="Task_SaveGitLab" name="OK" />
    <bpmn:sequenceFlow id="Flow_GitLab_Deploy" sourceRef="Task_SaveGitLab" targetRef="Task_Deploy" />
    <bpmn:sequenceFlow id="Flow_Deploy_Gate" sourceRef="Task_Deploy" targetRef="Gateway_Deploy" />
    <bpmn:sequenceFlow id="Flow_Deploy_Alert" sourceRef="Gateway_Deploy" targetRef="Task_DeployAlert" name="Сбой" />
    <bpmn:sequenceFlow id="Flow_Deploy_Notify" sourceRef="Gateway_Deploy" targetRef="Task_SendTestBot" name="OK" />
    <bpmn:sequenceFlow id="Flow_Alert_End" sourceRef="Task_DeployAlert" targetRef="EndEvent_1" />
    <bpmn:sequenceFlow id="Flow_Notify_Accept" sourceRef="Task_SendTestBot" targetRef="Task_Client_Accept" />
    <bpmn:sequenceFlow id="Flow_Accept_Close" sourceRef="Task_Client_Accept" targetRef="Task_Close" />
    <bpmn:sequenceFlow id="Flow_Close_End" sourceRef="Task_Close" targetRef="EndEvent_1" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Process_StudioBots">
      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1">
        <dc:Bounds x="152" y="102" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="140" y="145" width="60" height="27" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Onboard_di" bpmnElement="Task_Onboard">
        <dc:Bounds x="240" y="80" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AI_Clarify_di" bpmnElement="Task_AI_Clarify">
        <dc:Bounds x="390" y="80" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_BriefComplete_di" bpmnElement="Gateway_BriefComplete">
        <dc:Bounds x="535" y="95" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_SaveCRM_Draft_di" bpmnElement="Task_SaveCRM_Draft">
        <dc:Bounds x="240" y="260" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Client_Calc_di" bpmnElement="Task_Client_Calc">
        <dc:Bounds x="390" y="260" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_CalcPrice_di" bpmnElement="Task_CalcPrice">
        <dc:Bounds x="540" y="260" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_GenPaymentLink_di" bpmnElement="Task_GenPaymentLink">
        <dc:Bounds x="690" y="260" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Payment_di" bpmnElement="Task_Payment">
        <dc:Bounds x="840" y="260" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Payment_di" bpmnElement="Gateway_Payment">
        <dc:Bounds x="975" y="275" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_CRM_Paid_di" bpmnElement="Task_CRM_Paid">
        <dc:Bounds x="1070" y="260" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AI_Content_di" bpmnElement="Task_AI_Content">
        <dc:Bounds x="1220" y="260" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AI_Code_di" bpmnElement="Task_AI_Code">
        <dc:Bounds x="1370" y="260" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AI_Image_di" bpmnElement="Task_AI_Image">
        <dc:Bounds x="1520" y="260" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_AIFail_di" bpmnElement="Gateway_AIFail">
        <dc:Bounds x="1655" y="275" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_SaveGitLab_di" bpmnElement="Task_SaveGitLab">
        <dc:Bounds x="1750" y="260" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Deploy_di" bpmnElement="Task_Deploy">
        <dc:Bounds x="1900" y="260" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_ReaskCount_di" bpmnElement="Gateway_ReaskCount">
        <dc:Bounds x="535" y="200" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Manager_di" bpmnElement="Task_Manager">
        <dc:Bounds x="390" y="180" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_RetryLink_di" bpmnElement="Task_RetryLink">
        <dc:Bounds x="975" y="380" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AIRetry_di" bpmnElement="Task_AIRetry">
        <dc:Bounds x="1655" y="380" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_DeployAlert_di" bpmnElement="Task_DeployAlert">
        <dc:Bounds x="2035" y="380" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Deploy_di" bpmnElement="Gateway_Deploy">
        <dc:Bounds x="2035" y="275" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_SendTestBot_di" bpmnElement="Task_SendTestBot">
        <dc:Bounds x="2130" y="260" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Client_Accept_di" bpmnElement="Task_Client_Accept">
        <dc:Bounds x="2280" y="260" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Close_di" bpmnElement="Task_Close">
        <dc:Bounds x="2430" y="260" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_1_di" bpmnElement="EndEvent_1">
        <dc:Bounds x="2572" y="272" width="36" height="36" />
      </bpmndi:BPMNShape>
    
      <bpmndi:BPMNEdge bpmnElement="Flow_Reask_Onboard">
        <di:waypoint x="535" y="225" />
        <di:waypoint x="438" y="172" />
        <di:waypoint x="340" y="120" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="Flow_Retry_Pay">
        <di:waypoint x="975" y="420" />
        <di:waypoint x="958" y="360" />
        <di:waypoint x="940" y="300" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="Flow_Retry_AI">
        <di:waypoint x="1655" y="420" />
        <di:waypoint x="1488" y="360" />
        <di:waypoint x="1320" y="300" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="Flow_Start_Onboard">
        <di:waypoint x="188" y="120" />
        <di:waypoint x="214" y="120" />
        <di:waypoint x="240" y="120" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="Flow_Onboard_AI">
        <di:waypoint x="340" y="120" />
        <di:waypoint x="365" y="120" />
        <di:waypoint x="390" y="120" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="Flow_AI_GateBrief">
        <di:waypoint x="490" y="120" />
        <di:waypoint x="512" y="120" />
        <di:waypoint x="535" y="120" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="Flow_Gate_Reask">
        <di:waypoint x="560" y="145" />
        <di:waypoint x="560" y="172" />
        <di:waypoint x="560" y="200" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="Flow_Gate_CRM">
        <di:waypoint x="535" y="120" />
        <di:waypoint x="438" y="210" />
        <di:waypoint x="340" y="300" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="Flow_Reask_Manager">
        <di:waypoint x="535" y="225" />
        <di:waypoint x="512" y="222" />
        <di:waypoint x="490" y="220" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="Flow_Manager_CRM">
        <di:waypoint x="390" y="220" />
        <di:waypoint x="365" y="260" />
        <di:waypoint x="340" y="300" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="Flow_CRM_Calc">
        <di:waypoint x="340" y="300" />
        <di:waypoint x="365" y="300" />
        <di:waypoint x="390" y="300" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="Flow_Calc_Price">
        <di:waypoint x="490" y="300" />
        <di:waypoint x="515" y="300" />
        <di:waypoint x="540" y="300" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="Flow_Price_Link">
        <di:waypoint x="640" y="300" />
        <di:waypoint x="665" y="300" />
        <di:waypoint x="690" y="300" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="Flow_Link_Pay">
        <di:waypoint x="790" y="300" />
        <di:waypoint x="815" y="300" />
        <di:waypoint x="840" y="300" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="Flow_Pay_Gate">
        <di:waypoint x="940" y="300" />
        <di:waypoint x="958" y="300" />
        <di:waypoint x="975" y="300" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="Flow_Pay_Retry">
        <di:waypoint x="1000" y="325" />
        <di:waypoint x="1012" y="352" />
        <di:waypoint x="1025" y="380" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="Flow_Pay_UpdateCRM">
        <di:waypoint x="1025" y="300" />
        <di:waypoint x="1048" y="300" />
        <di:waypoint x="1070" y="300" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="Flow_Paid_AI">
        <di:waypoint x="1170" y="300" />
        <di:waypoint x="1195" y="300" />
        <di:waypoint x="1220" y="300" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="Flow_Content_Code">
        <di:waypoint x="1320" y="300" />
        <di:waypoint x="1345" y="300" />
        <di:waypoint x="1370" y="300" />
