<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_Case2"
                  targetNamespace="http://bpmn.io/schema/bpmn">

  <bpmn:process id="Process_ITRecruiting" name="Рекрутинг IT: от резюме до оффера за 24 часа" isExecutable="false">
    <bpmn:documentation>Автоматизация подбора: сбор резюме из всех каналов, AI-скрининг, планирование интервью, фидбэк, генерация и подпись оффера.</bpmn:documentation>

    <!-- Start: резюме поступило -->
    <bpmn:startEvent id="StartEvent_1" name="Резюме получено (email / Telegram / форма / hh.ru)">
      <bpmn:outgoing>Flow_Start_Collect</bpmn:outgoing>
    </bpmn:startEvent>

    <!-- Сценарий 1: Сбор и нормализация -->
    <bpmn:serviceTask id="Task_Collect" name="Сбор: скачивание вложения, извлечение текста (PDF/DOCX), сохранение в Drive">
      <bpmn:incoming>Flow_Start_Collect</bpmn:incoming>
      <bpmn:outgoing>Flow_Collect_Normalize</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_Normalize" name="Приведение к единому формату, запись в Airtable (статус «новый»)">
      <bpmn:incoming>Flow_Collect_Normalize</bpmn:incoming>
      <bpmn:outgoing>Flow_Normalize_Dupe</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_Dupe" name="Дубль по email/телефону?">
      <bpmn:incoming>Flow_Normalize_Dupe</bpmn:incoming>
      <bpmn:outgoing>Flow_Dupe_Skip</bpmn:outgoing>
      <bpmn:outgoing>Flow_Dupe_AI</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="EndEvent_Dupe" name="Дубль — не создавать">
      <bpmn:incoming>Flow_Dupe_Skip</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Сценарий 2: AI-скрининг и матчинг -->
    <bpmn:serviceTask id="Task_AI_Parse" name="OpenAI: извлечь ФИО, email, телефон, опыт, навыки; match_score по вакансии">
      <bpmn:incoming>Flow_Dupe_AI</bpmn:incoming>
      <bpmn:outgoing>Flow_Parse_Gate</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_OCR" name="Данные извлечены?">
      <bpmn:incoming>Flow_Parse_Gate</bpmn:incoming>
      <bpmn:outgoing>Flow_OCR_Request</bpmn:outgoing>
      <bpmn:outgoing>Flow_OCR_Update</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_RequestReload" name="Запрос перезагрузки резюме (плохой OCR)">
      <bpmn:incoming>Flow_OCR_Request</bpmn:incoming>
      <bpmn:outgoing>Flow_Request_End</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="EndEvent_Request" name="Ожидание нового файла">
      <bpmn:incoming>Flow_Request_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:serviceTask id="Task_UpdateAirtable" name="Обновление записи: skills, match_score, структурированные поля">
      <bpmn:incoming>Flow_OCR_Update</bpmn:incoming>
      <bpmn:outgoing>Flow_Update_Match</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_Match" name="match_score">
      <bpmn:incoming>Flow_Update_Match</bpmn:incoming>
      <bpmn:outgoing>Flow_Match_Reject</bpmn:outgoing>
      <bpmn:outgoing>Flow_Match_Invite</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_Reject" name="AI: вежливый отказ (персонализированное письмо)">
      <bpmn:incoming>Flow_Match_Reject</bpmn:incoming>
      <bpmn:outgoing>Flow_Reject_End</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="EndEvent_Reject" name="Кандидат отклонён">
      <bpmn:incoming>Flow_Reject_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:serviceTask id="Task_Invite" name="Отправка приглашения «Выбрать время интервью» + уведомление HR в Telegram">
      <bpmn:incoming>Flow_Match_Invite</bpmn:incoming>
      <bpmn:outgoing>Flow_Invite_Calendar</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Сценарий 3: Планирование интервью -->
    <bpmn:receiveTask id="Task_Calendly" name="Кандидат выбрал слот (Calendly webhook)">
      <bpmn:incoming>Flow_Invite_Calendar</bpmn:incoming>
      <bpmn:outgoing>Flow_Cal_Book</bpmn:outgoing>
    </bpmn:receiveTask>
    <bpmn:serviceTask id="Task_BookMeeting" name="Создание события в Google Calendar, генерация Zoom-ссылки, подтверждение кандидату">
      <bpmn:incoming>Flow_Cal_Book</bpmn:incoming>
      <bpmn:outgoing>Flow_Book_Interview</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="Task_Interview" name="Проведение интервью (HR + техлид)">
      <bpmn:incoming>Flow_Book_Interview</bpmn:incoming>
      <bpmn:outgoing>Flow_Interview_Gate</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_NoShow" name="Кандидат пришёл?">
      <bpmn:incoming>Flow_Interview_Gate</bpmn:incoming>
      <bpmn:outgoing>Flow_NoShow_Reschedule</bpmn:outgoing>
      <bpmn:outgoing>Flow_Show_Feedback</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:exclusiveGateway id="Gateway_Reschedule" name="Повтор &lt; 2 раз?">
      <bpmn:incoming>Flow_NoShow_Reschedule</bpmn:incoming>
      <bpmn:outgoing>Flow_Reschedule_Invite</bpmn:outgoing>
      <bpmn:outgoing>Flow_NoShow_End</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_Reschedule" name="Перепланирование через бота">
      <bpmn:incoming>Flow_Reschedule_Invite</bpmn:incoming>
      <bpmn:outgoing>Flow_Reschedule_Cal</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="EndEvent_NoShow" name="Статус No-show">
      <bpmn:incoming>Flow_NoShow_End</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Сценарий 4: Сбор фидбэка -->
    <bpmn:serviceTask id="Task_Feedback" name="Форма в Telegram для HR и техлида (оценка, комментарии) → запись в Airtable">
      <bpmn:incoming>Flow_Show_Feedback</bpmn:incoming>
      <bpmn:outgoing>Flow_Feedback_Gate</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_Approved" name="Оценка ≥ 4?">
      <bpmn:incoming>Flow_Feedback_Gate</bpmn:incoming>
      <bpmn:outgoing>Flow_Approved_Reject</bpmn:outgoing>
      <bpmn:outgoing>Flow_Approved_Offer</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_RejectAfter" name="Отказ после интервью">
      <bpmn:incoming>Flow_Approved_Reject</bpmn:incoming>
      <bpmn:outgoing>Flow_RejectAfter_End</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="EndEvent_RejectAfter" name="Кандидат отклонён">
      <bpmn:incoming>Flow_RejectAfter_End</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Сценарий 5: Генерация и отправка оффера -->
    <bpmn:serviceTask id="Task_GenOffer" name="Подстановка данных в шаблон (Google Docs), отправка на подпись (SimpleSign)">
      <bpmn:incoming>Flow_Approved_Offer</bpmn:incoming>
      <bpmn:outgoing>Flow_Offer_Sign</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:receiveTask id="Task_Sign" name="Кандидат подписал оффер">
      <bpmn:incoming>Flow_Offer_Sign</bpmn:incoming>
      <bpmn:outgoing>Flow_Sign_Notify</bpmn:outgoing>
    </bpmn:receiveTask>
    <bpmn:serviceTask id="Task_NotifyHired" name="Уведомление HR и бухгалтерии, статус «Hired»">
      <bpmn:incoming>Flow_Sign_Notify</bpmn:incoming>
      <bpmn:outgoing>Flow_Hired_End</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="EndEvent_Hired" name="Кандидат нанят">
      <bpmn:incoming>Flow_Hired_End</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Flows -->
    <bpmn:sequenceFlow id="Flow_Start_Collect" sourceRef="StartEvent_1" targetRef="Task_Collect" />
    <bpmn:sequenceFlow id="Flow_Collect_Normalize" sourceRef="Task_Collect" targetRef="Task_Normalize" />
    <bpmn:sequenceFlow id="Flow_Normalize_Dupe" sourceRef="Task_Normalize" targetRef="Gateway_Dupe" />
    <bpmn:sequenceFlow id="Flow_Dupe_Skip" sourceRef="Gateway_Dupe" targetRef="EndEvent_Dupe" name="Да" />
    <bpmn:sequenceFlow id="Flow_Dupe_AI" sourceRef="Gateway_Dupe" targetRef="Task_AI_Parse" name="Нет" />
    <bpmn:sequenceFlow id="Flow_Parse_Gate" sourceRef="Task_AI_Parse" targetRef="Gateway_OCR" />
    <bpmn:sequenceFlow id="Flow_OCR_Request" sourceRef="Gateway_OCR" targetRef="Task_RequestReload" name="Нет" />
    <bpmn:sequenceFlow id="Flow_Request_End" sourceRef="Task_RequestReload" targetRef="EndEvent_Request" />
    <bpmn:sequenceFlow id="Flow_OCR_Update" sourceRef="Gateway_OCR" targetRef="Task_UpdateAirtable" name="Да" />
    <bpmn:sequenceFlow id="Flow_Update_Match" sourceRef="Task_UpdateAirtable" targetRef="Gateway_Match" />
    <bpmn:sequenceFlow id="Flow_Match_Reject" sourceRef="Gateway_Match" targetRef="Task_Reject" name="&lt; 30%" />
    <bpmn:sequenceFlow id="Flow_Reject_End" sourceRef="Task_Reject" targetRef="EndEvent_Reject" />
    <bpmn:sequenceFlow id="Flow_Match_Invite" sourceRef="Gateway_Match" targetRef="Task_Invite" name="&gt; 70%" />
    <bpmn:sequenceFlow id="Flow_Invite_Calendar" sourceRef="Task_Invite" targetRef="Task_Calendly" />
    <bpmn:sequenceFlow id="Flow_Cal_Book" sourceRef="Task_Calendly" targetRef="Task_BookMeeting" />
    <bpmn:sequenceFlow id="Flow_Book_Interview" sourceRef="Task_BookMeeting" targetRef="Task_Interview" />
    <bpmn:sequenceFlow id="Flow_Interview_Gate" sourceRef="Task_Interview" targetRef="Gateway_NoShow" />
    <bpmn:sequenceFlow id="Flow_NoShow_Reschedule" sourceRef="Gateway_NoShow" targetRef="Gateway_Reschedule" name="Нет" />
    <bpmn:sequenceFlow id="Flow_Reschedule_Invite" sourceRef="Gateway_Reschedule" targetRef="Task_Reschedule" name="Да" />
    <bpmn:sequenceFlow id="Flow_Reschedule_Cal" sourceRef="Task_Reschedule" targetRef="Task_Calendly" />
    <bpmn:sequenceFlow id="Flow_NoShow_End" sourceRef="Gateway_Reschedule" targetRef="EndEvent_NoShow" name="Нет" />
    <bpmn:sequenceFlow id="Flow_Show_Feedback" sourceRef="Gateway_NoShow" targetRef="Task_Feedback" name="Да" />
    <bpmn:sequenceFlow id="Flow_Feedback_Gate" sourceRef="Task_Feedback" targetRef="Gateway_Approved" />
    <bpmn:sequenceFlow id="Flow_Approved_Reject" sourceRef="Gateway_Approved" targetRef="Task_RejectAfter" name="Нет" />
    <bpmn:sequenceFlow id="Flow_RejectAfter_End" sourceRef="Task_RejectAfter" targetRef="EndEvent_RejectAfter" />
    <bpmn:sequenceFlow id="Flow_Approved_Offer" sourceRef="Gateway_Approved" targetRef="Task_GenOffer" name="Да" />
    <bpmn:sequenceFlow id="Flow_Offer_Sign" sourceRef="Task_GenOffer" targetRef="Task_Sign" />
    <bpmn:sequenceFlow id="Flow_Sign_Notify" sourceRef="Task_Sign" targetRef="Task_NotifyHired" />
    <bpmn:sequenceFlow id="Flow_Hired_End" sourceRef="Task_NotifyHired" targetRef="EndEvent_Hired" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Process_ITRecruiting">
      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1">
        <dc:Bounds x="152" y="102" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Collect_di" bpmnElement="Task_Collect">
        <dc:Bounds x="240" y="80" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Normalize_di" bpmnElement="Task_Normalize">
        <dc:Bounds x="390" y="80" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Dupe_di" bpmnElement="Gateway_Dupe">
        <dc:Bounds x="535" y="95" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AI_Parse_di" bpmnElement="Task_AI_Parse">
        <dc:Bounds x="640" y="80" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_OCR_di" bpmnElement="Gateway_OCR">
        <dc:Bounds x="785" y="95" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_UpdateAirtable_di" bpmnElement="Task_UpdateAirtable">
        <dc:Bounds x="890" y="80" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Match_di" bpmnElement="Gateway_Match">
        <dc:Bounds x="1035" y="95" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Invite_di" bpmnElement="Task_Invite">
        <dc:Bounds x="1140" y="80" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Calendly_di" bpmnElement="Task_Calendly">
        <dc:Bounds x="1290" y="80" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_BookMeeting_di" bpmnElement="Task_BookMeeting">
        <dc:Bounds x="1440" y="80" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Interview_di" bpmnElement="Task_Interview">
        <dc:Bounds x="1590" y="80" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_NoShow_di" bpmnElement="Gateway_NoShow">
        <dc:Bounds x="1735" y="95" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Feedback_di" bpmnElement="Task_Feedback">
        <dc:Bounds x="1840" y="80" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Approved_di" bpmnElement="Gateway_Approved">
        <dc:Bounds x="1985" y="95" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_GenOffer_di" bpmnElement="Task_GenOffer">
        <dc:Bounds x="2090" y="80" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Sign_di" bpmnElement="Task_Sign">
        <dc:Bounds x="2240" y="80" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_NotifyHired_di" bpmnElement="Task_NotifyHired">
        <dc:Bounds x="2390" y="80" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_Hired_di" bpmnElement="EndEvent_Hired">
        <dc:Bounds x="2532" y="102" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_Dupe_di" bpmnElement="EndEvent_Dupe">
        <dc:Bounds x="552" y="200" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_Reject_di" bpmnElement="EndEvent_Reject">
        <dc:Bounds x="1035" y="200" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_NoShow_di" bpmnElement="EndEvent_NoShow">
        <dc:Bounds x="1735" y="200" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_RejectAfter_di" bpmnElement="EndEvent_RejectAfter">
        <dc:Bounds x="1985" y="200" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_RequestReload_di" bpmnElement="Task_RequestReload">
        <dc:Bounds x="785" y="200" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_Request_di" bpmnElement="EndEvent_Request">
        <dc:Bounds x="822" y="320" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Reject_di" bpmnElement="Task_Reject">
        <dc:Bounds x="1035" y="200" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Reschedule_di" bpmnElement="Gateway_Reschedule">
        <dc:Bounds x="1735" y="200" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Reschedule_di" bpmnElement="Task_Reschedule">
        <dc:Bounds x="1590" y="200" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_RejectAfter_di" bpmnElement="Task_RejectAfter">
        <dc:Bounds x="1840" y="200" width="100" height="80" />
      </bpmndi:BPMNShape>
    
      <bpmndi:BPMNEdge bpmnElement="Flow_Start_Collect">
        <di:waypoint x="188" y="120" />
        <di:waypoint x="214" y="120" />
        <di:waypoint x="240" y="120" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="Flow_Collect_Normalize">
        <di:waypoint x="340" y="120" />
        <di:waypoint x="365" y="120" />
        <di:waypoint x="390" y="120" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="Flow_Normalize_Dupe">
        <di:waypoint x="490" y="120" />
        <di:waypoint x="512" y="120" />
        <di:waypoint x="535" y="120" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="Flow_Dupe_Skip">
        <di:waypoint x="560" y="145" />
        <di:waypoint x="565" y="172" />
        <di:waypoint x="570" y="200" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="Flow_Dupe_AI">
        <di:waypoint x="585" y="120" />
        <di:waypoint x="612" y="120" />
        <di:waypoint x="640" y="120" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="Flow_Parse_Gate">
        <di:waypoint x="740" y="120" />
        <di:waypoint x="762" y="120" />
        <di:waypoint x="785" y="120" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="Flow_OCR_Request">
        <di:waypoint x="810" y="145" />
        <di:waypoint x="822" y="172" />
        <di:waypoint x="835" y="200" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="Flow_Request_End">
        <di:waypoint x="835" y="280" />
        <di:waypoint x="838" y="300" />
        <di:waypoint x="840" y="320" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="Flow_OCR_Update">
        <di:waypoint x="835" y="120" />
        <di:waypoint x="862" y="120" />
        <di:waypoint x="890" y="120" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="Flow_Update_Match">
        <di:waypoint x="990" y="120" />
        <di:waypoint x="1012" y="120" />
        <di:waypoint x="1035" y="120" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="Flow_Match_Reject">
        <di:waypoint x="1060" y="145" />
        <di:waypoint x="1072" y="172" />
        <di:waypoint x="1085" y="200" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="Flow_Reject_End">
        <di:waypoint x="1035" y="240" />
        <di:waypoint x="1053" y="229" />
        <di:waypoint x="1071" y="218" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="Flow_Match_Invite">
        <di:waypoint x="1085" y="120" />
        <di:waypoint x="1112" y="120" />
        <di:waypoint x="1140" y="120" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="Flow_Invite_Calendar">
        <di:waypoint x="1240" y="120" />
        <di:waypoint x="1265" y="120" />
        <di:waypoint x="1290" y="120" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="Flow_Cal_Book">
        <di:waypoint x="1390" y="120" />
        <di:waypoint x="1415" y="120" />
        <di:waypoint x="1440" y="120" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="Flow_Book_Interview">
        <di:waypoint x="1540" y="120" />
        <di:waypoint x="1565" y="120" />
        <di:waypoint x="1590" y="120" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="Flow_Interview_Gate">
        <di:waypoint x="1690" y="120" />
        <di:waypoint x="1712" y="120" />
        <di:waypoint x="1735" y="120" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="Flow_NoShow_Reschedule">
