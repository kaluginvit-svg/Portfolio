flowchart LR
    subgraph Вход
        A[Резюме] --> B[Сбор и нормализация]
        B --> C{Дубль?}
        C -->|Да| X1((Стоп))
        C -->|Нет| D[AI: парсинг, match]
    end
    subgraph Скрининг
        D --> E{Данные OK?}
        E -->|Нет| F[Запрос перезагрузки]
        E -->|Да| G[Обновление Airtable]
        G --> H{match > 70%?}
        H -->|Нет| I[Отказ]
        H -->|Да| J[Приглашение]
    end
    subgraph Интервью
        J --> K[Calendly]
        K --> L[Встреча Zoom]
        L --> M{Пришёл?}
        M -->|Нет| N{Повтор < 2?}
        N -->|Да| K
        N -->|Нет| X2((No-show))
        M -->|Да| O[Фидбэк]
        O --> P{Оценка ≥ 4?}
        P -->|Нет| X3((Отказ))
        P -->|Да| Q[Оффер]
        Q --> R[Подпись]
        R --> S[Hired]
    end
    S --> X4((Конец))
