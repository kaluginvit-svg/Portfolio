# Backend UX-рецензент: FastAPI + Uvicorn
# Сборка из корня проекта: docker build -f Backend-Dockerfile -t ux-reviewer-backend .
FROM python:3.11-slim

# Кодировка UTF-8 (кириллица в ответах и логах)
ENV LANG=C.UTF-8
ENV LC_ALL=C.UTF-8
ENV PYTHONIOENCODING=utf-8
ENV PYTHONUTF8=1

WORKDIR /app

# Системные зависимости для lxml (опционально, bs4 может работать без)
RUN apt-get update && apt-get install -y --no-install-recommends \
    libxml2 \
    && rm -rf /var/lib/apt/lists/*

# Зависимости Python
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Код приложения: app/, ux_reviewer/ (frontend и прочее в .dockerignore)
COPY . .

# Не root в контейнере
RUN adduser --disabled-password --gecos "" appuser && chown -R appuser:appuser /app
USER appuser

EXPOSE 8000
# Production: без --reload. Для dev в docker-compose переопределить command с --reload
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]
